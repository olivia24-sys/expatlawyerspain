# Cloudflare Pages security headers — applied to every route.
# X-Content-Type-Options and Referrer-Policy were already set at the edge; repeated here so the
# policy is explicit and version-controlled. HSTS + X-Frame-Options + Permissions-Policy are new.
# The CSP is Report-Only for now (browsers report violations but do NOT block), so it cannot break
# GA4 / Turnstile / Ahrefs / Formspree / inline handlers. Review reports, then switch the header
# name to "Content-Security-Policy" to enforce.
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=(), usb=()
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://static.cloudflareinsights.com https://analytics.ahrefs.com https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com https://static.cloudflareinsights.com https://cloudflareinsights.com https://analytics.ahrefs.com; frame-src https://challenges.cloudflare.com; form-action https://formspree.io; base-uri 'self'; object-src 'none'
